BOT_TOKEN=123456:ABCDEF
OWNER_IDS=123456789
DATABASE_URL=postgresql://user:password@host:5432/db
JOIN_VALIDATION_MINUTES=5
MINIMUM_VIP_MINUTES=10
VIP_LINK_TTL_MINUTES=15
TRIAL_MINUTES=2
KICK_RETRY_SECONDS=20
HEALTH_INTERVAL_MINUTES=5
TREND_DROP_PERCENT=20
TIMEZONE=Europe/Paris

# Délai avant de confirmer qu’un groupe est définitivement perdu
GROUP_LOST_GRACE_MINUTES=10
# Pause entre deux envois de broadcast (0.05 ≈ 20 messages/seconde)
BROADCAST_DELAY_SECONDS=0.05
